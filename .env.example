# Meta Marketing API — Ótica Alê Eyewear
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no git.

# System User Token (nunca expira — use System User, não User Token)
META_ACCESS_TOKEN=seu_system_user_token_aqui

# Ad Account ID (sem o prefixo "act_" — o script adiciona automaticamente)
META_AD_ACCOUNT_ID=XXXXXXXXXXXXXXXXX

# Versão da API do Meta (mantenha atualizado conforme changelog do Meta)
META_API_VERSION=v22.0
